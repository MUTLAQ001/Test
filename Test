}

let wizardTrack = 'bachelor';
wizardOverlay.addEventListener('click', e => {
    if (e.target === wizardOverlay) { closeOverlay(wizardOverlay); return; }
    if (e.target.closest('[data-close="wizard"]')) { closeOverlay(wizardOverlay); return; }
    const back = e.target.closest('[data-wizback]');
    if (back) {
        if (back.getAttribute('data-wizback') === '1') wizardStep1();
        else wizardStep2(back.getAttribute('data-track'));
        return;
    }
    const college = e.target.closest('[data-college]');
    if (college) { wizardPack(college.getAttribute('data-college'), wizardTrack); return; }
    const track = e.target.closest('[data-track]');
    if (track) { wizardStep2(track.getAttribute('data-track')); return; }
    const pinall = e.target.closest('[data-pinall]');
    if (pinall) {
        const urls = JSON.parse(pinall.getAttribute('data-pinall'));
        urls.forEach(u => { if (!isPinned(u)) pins.unshift(u); });
        lsSet('qu-pins', pins);
        renderPersonal(); syncPinStates();
        toast('تم تثبيت الحزمة في مجموعاتي');
        closeOverlay(wizardOverlay);
    }
});

