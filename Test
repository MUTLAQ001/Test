function normalizeAr(s) {
    return s.toLowerCase()
        .replace(/[\u064B-\u0652\u0640]/g, '')
        .replace(/[أإآ]/g, 'ا')
        .replace(/ة/g, 'ه')
        .replace(/ى/g, 'ي')
        .replace(/ؤ/g, 'و')
        .replace(/ئ/g, 'ي');
}

function slugify(name) { return name.trim().replace(/\s+/g, '-'); }

function lsGet(k, def) { try { const v = localStorage.getItem(k); return v ? JSON.parse(v) : def; } catch (e) { return def; } }
function lsSet(k, v) { try { localStorage.setItem(k, JSON.stringify(v)); } catch (e) {} }

let pins = lsGet('qu-pins', []);
let usage = lsGet('qu-usage', {});

const FLAT = {};
const SLUG_TO_COLLEGE = {};
DATA.forEach(section => section.colleges.forEach(col => {
    col._slug = slugify(col.name);
    col._group = section.group;
    SLUG_TO_COLLEGE[col._slug] = col;
    const all = [];
    if (col.general) all.push(col.general);
    col.items.forEach(i => all.push(i));
    col._all = all;
    all.forEach(it => { FLAT[it.url] = { name: it.name, url: it.url, college: col.name, group: section.group }; });
}));

function isPinned(url) { return pins.indexOf(url) !== -1; }
function togglePin(url) {
    if (isPinned(url)) pins = pins.filter(u => u !== url);
    else pins = [url, ...pins];
    lsSet('qu-pins', pins);
    renderPersonal();
    syncPinStates();
    toast(isPinned(url) ? 'تم التثبيت في مجموعاتي' : 'تمت الإزالة من مجموعاتي');
}

function trackUse(url) { usage[url] = (usage[url] || 0) + 1; lsSet('qu-usage', usage); }

function toast(msg) {
    toastText.textContent = msg;
    toastEl.classList.add('show');
    clearTimeout(toast._t);
    toast._t = setTimeout(() => toastEl.classList.remove('show'), 2600);
}

function copyText(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text).catch(() => fallbackCopy(text));
    }
    return fallbackCopy(text);
}
function fallbackCopy(text) {
    try {
        const ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.focus(); ta.select();
        document.execCommand('copy'); document.body.removeChild(ta);
    } catch (e) {}
    return Promise.resolve();
}

function toolsHtml(url, removeLabel) {
    const active = isPinned(url) ? ' active' : '';
    const pinTitle = removeLabel ? 'إزالة من مجموعاتي' : 'تثبيت في مجموعاتي';
    let html = `<span class="item-tools"><span class="item-tool pin${active}" role="button" tabindex="0" data-pin="${url}" title="${pinTitle}"><i class="fas fa-thumbtack"></i></span>`;
    if (!removeLabel) html += `<span class="item-tool report" role="button" tabindex="0" data-report="${url}" title="بلاغ رابط معطل"><i class="fas fa-flag"></i></span>`;
    html += `</span>`;
    return html;
}

function itemHtml(it, isGeneral) {
    const cls = ['item-link'];
    if (isGeneral) cls.push('general');
    if (it.girls) cls.push('girls');
    const badge = it.girls ? '<span class="girls-badge">طالبات</span>' : '';
    const circleIcon = isGeneral ? 'fa-users' : 'fa-arrow-left';
    return `<a class="${cls.join(' ')}" href="${it.url}" target="_blank" rel="noopener" data-url="${it.url}" data-name="${it.name}">
        <span class="item-name"><span>${it.name}</span>${badge}</span>
        ${toolsHtml(it.url, false)}
        <span class="item-icon-circle"><i class="fas ${circleIcon}"></i></span>
    </a>`;
}

function collegeHtml(section, college, cardIndex) {
    let itemsHtml = '';
    let count = college.items.length;
    if (college.general) { itemsHtml += itemHtml(college.general, true); count++; }
    college.items.forEach(it => { itemsHtml += itemHtml(it, false); });

    const extra = SYNONYMS[college.name] || '';
    const searchable = [college.name, college.general ? college.general.name : '', ...college.items.map(i => i.name), extra].join(' ');
    const delay = (cardIndex % 6) * 0.06;
    const slug = college._slug;

    return `
    <div class="college-card" data-slug="${slug}" data-searchable="${searchable}" style="animation-delay:${delay}s">
        <div class="college-head" role="button" tabindex="0" aria-expanded="false">
            <div class="college-head-right">
                <div class="college-icon"><i class="fas ${college.icon}"></i></div>
                <div>
                    <div class="college-name">${college.name}</div>
                    <div class="college-count"><i class="fas fa-link"></i>${count} رابط</div>
                </div>
            </div>
            <i class="fas fa-chevron-down chevron"></i>
        </div>
        <div class="college-body">
            <div class="items-wrap">${itemsHtml}</div>
            <div class="card-actions">
                <button class="card-action-btn" data-share="${slug}"><i class="fas fa-image"></i>مشاركة كصورة</button>
                <button class="card-action-btn" data-copylink="${slug}"><i class="fas fa-link"></i>نسخ الرابط</button>
            </div>
        </div>
    </div>`;
}

function render() {
    let html = '';
    let cardIndex = 0;
    let totalColleges = 0;
    let totalLinks = 0;

    DATA.forEach(section => {
        let collegesHtml = '';
        section.colleges.forEach(c => {
            collegesHtml += collegeHtml(section, c, cardIndex);
            cardIndex++;
            totalColleges++;
            totalLinks += c.items.length + (c.general ? 1 : 0);
        });
        html += `
        <div class="group-section" data-group="${section.group}">
            <div class="group-section-title"><i class="fas ${section.sectionIcon}"></i>${section.sectionLabel}</div>
            <div class="title-divider"></div>
            ${collegesHtml}
        </div>`;
    });
    resultsEl.innerHTML = html;

    heroStatsEl.innerHTML = `
        <div class="hero-stat"><i class="fas fa-link"></i>${totalLinks} رابط</div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat"><i class="fas fa-building-columns"></i>${totalColleges} تخصص وكلية</div>`;
}

function flatItemHtml(entry, opts) {
    opts = opts || {};
    const collegeTag = opts.showCollege && entry.college ? `<span class="flat-item-college">${entry.college}</span>` : '';
    const useTag = opts.count ? `<span class="use-count">${opts.count}</span>` : '';
    return `<a class="item-link" href="${entry.url}" target="_blank" rel="noopener" data-url="${entry.url}" data-name="${entry.name}">
        <span class="item-name"><span>${entry.name}</span>${collegeTag}</span>
        ${toolsHtml(entry.url, true)}
        ${useTag}
        <span class="item-icon-circle"><i class="fas fa-arrow-left"></i></span>
    </a>`;
}

function renderPersonal() {
    const validPins = pins.filter(u => FLAT[u]);
    if (validPins.length) {
        pinnedMount.classList.remove('mount-empty');
        pinnedMount.innerHTML = `<div class="group-section pinned-section">
            <div class="group-section-title"><i class="fas fa-thumbtack"></i>مجموعاتي</div>
            <div class="title-divider"></div>
            <div class="flat-list">${validPins.map(u => flatItemHtml(FLAT[u], { showCollege: true })).join('')}</div>
        </div>`;
    } else { pinnedMount.classList.add('mount-empty'); pinnedMount.innerHTML = ''; }

    const entries = Object.keys(usage)
        .filter(u => FLAT[u] && !isPinned(u))
        .map(u => ({ url: u, count: usage[u] }))
        .filter(e => e.count >= 2)
        .sort((a, b) => b.count - a.count)
        .slice(0, 4);
    if (entries.length) {
        mostusedMount.classList.remove('mount-empty');
        mostusedMount.innerHTML = `<div class="group-section mostused-section">
            <div class="group-section-title"><i class="fas fa-fire"></i>الأكثر فتحًا</div>
            <div class="title-divider"></div>
            <div class="flat-list">${entries.map(e => flatItemHtml(FLAT[e.url], { showCollege: true, count: e.count })).join('')}</div>
        </div>`;
    } else { mostusedMount.classList.add('mount-empty'); mostusedMount.innerHTML = ''; }
}

function syncPinStates() {
    document.querySelectorAll('.item-tool.pin').forEach(el => {
        el.classList.toggle('active', isPinned(el.getAttribute('data-pin')));
    });
}

function setCardOpen(card, open) {
    card.classList.toggle('open', open);
    const head = card.querySelector('.college-head');
    if (head) head.setAttribute('aria-expanded', open ? 'true' : 'false');
}

function applyFilters() {
    const q = normalizeAr(searchInput.value.trim());
    const latinShort = /^[a-z0-9]{1,3}$/.test(q);
    searchClear.style.display = q ? 'flex' : 'none';
    let anyVisible = false;

    document.querySelectorAll('#results .group-section').forEach(section => {
        const groupMatch = currentFilter === 'all' || section.dataset.group === currentFilter;
        let sectionHasVisible = false;

        section.querySelectorAll('.college-card').forEach(card => {
            const text = normalizeAr(card.dataset.searchable);
            let searchMatch;
            if (!q) searchMatch = true;
            else if (latinShort) searchMatch = text.split(/\s+/).some(t => t.startsWith(q));
            else searchMatch = text.includes(q);
            const visible = groupMatch && searchMatch;
            card.classList.toggle('filter-hidden', !visible);
            if (visible) { sectionHasVisible = true; anyVisible = true; }
            setCardOpen(card, !!q && visible);
        });

        section.classList.toggle('filter-hidden', !sectionHasVisible);
    });

    noResultsEl.style.display = anyVisible ? 'none' : 'block';
}

function focusCollege(slug) {
    const cards = resultsEl.querySelectorAll('.college-card');
    for (const card of cards) {
        if (card.dataset.slug === slug) {
            currentFilter = 'all';
            document.querySelectorAll('.chip').forEach(c => c.classList.toggle('selected', c.dataset.filter === 'all'));
            searchInput.value = '';
            applyFilters();
            setCardOpen(card, true);
            card.classList.add('glow');
            setTimeout(() => card.classList.remove('glow'), 3200);
            card.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return true;
        }
    }
    return false;
}

function handleHash() {
