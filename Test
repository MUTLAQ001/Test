    pack.push({ name: 'النقل الجامعي', url: 'https://t.me/Qassimqubuses' });
    pack.push({ name: track === 'diploma' ? 'تجميعات مواد الدبلوم' : 'تجميعات المواد العامة', url: track === 'diploma' ? 'https://t.me/APPQUEXS' : 'https://t.me/ExamsQU' });
    pack.push({ name: 'الأندية الطلابية', url: 'https://t.me/clubsQU' });

    const rows = pack.map(p => `<a class="item-link" href="${p.url}" target="_blank" rel="noopener" data-url="${p.url}" data-name="${p.name}">
        <span class="item-name"><span>${p.name}</span></span>
