function ensureFonts() {
    if (!document.fonts || !document.fonts.load) return Promise.resolve();
    return Promise.all([
        document.fonts.load('800 72px "Alexandria"'),
        document.fonts.load('700 34px "IBM Plex Sans Arabic"'),
        document.fonts.load('600 30px "IBM Plex Sans Arabic"')
    ]).catch(() => {});
}

function roundRect(ctx, x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
}

function drawQR(ctx, text, x, y, size) {
    if (typeof qrcode === 'undefined') return;
    const qr = qrcode(0, 'M');
    qr.addData(text);
    qr.make();
    const n = qr.getModuleCount();
    const cell = size / n;
    ctx.fillStyle = '#ffffff';
    roundRect(ctx, x - 18, y - 18, size + 36, size + 36, 22);
    ctx.fill();
    ctx.fillStyle = '#0f2b48';
    for (let r = 0; r < n; r++) {
        for (let c = 0; c < n; c++) {
            if (qr.isDark(r, c)) ctx.fillRect(Math.floor(x + c * cell), Math.floor(y + r * cell), Math.ceil(cell), Math.ceil(cell));
        }
    }
}

async function buildShareCanvas(col) {
    const W = 1080, H = 1350;
    const canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');
    await ensureFonts();

    const g = ctx.createLinearGradient(0, 0, W, H);
    g.addColorStop(0, '#0f2b48'); g.addColorStop(0.55, '#14385d'); g.addColorStop(1, '#11554f');
    ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);

    ctx.fillStyle = 'rgba(255,255,255,0.05)';
    for (let yy = 60; yy < H; yy += 46) for (let xx = 60; xx < W; xx += 46) { ctx.beginPath(); ctx.arc(xx, yy, 1.3, 0, 7); ctx.fill(); }

    const rg = ctx.createRadialGradient(W - 120, 130, 10, W - 120, 130, 340);
    rg.addColorStop(0, 'rgba(77,216,200,0.30)'); rg.addColorStop(1, 'rgba(77,216,200,0)');
    ctx.fillStyle = rg; ctx.fillRect(0, 0, W, H);

    ctx.direction = 'rtl';
    ctx.textAlign = 'right';
    const RX = W - 90;

    ctx.fillStyle = 'rgba(255,255,255,0.72)';
    ctx.font = '600 30px "IBM Plex Sans Arabic"';
    ctx.fillText('جامعة القصيم', RX, 150);

    let fs = 72;
    ctx.font = `800 ${fs}px "Alexandria","IBM Plex Sans Arabic"`;
    while (ctx.measureText(col.name).width > W - 180 && fs > 44) { fs -= 4; ctx.font = `800 ${fs}px "Alexandria","IBM Plex Sans Arabic"`; }
    ctx.fillStyle = '#ffffff';
    ctx.fillText(col.name, RX, 245);

    ctx.fillStyle = '#4dd8c8';
    ctx.fillRect(RX - 160, 290, 160, 6);

    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '600 28px "IBM Plex Sans Arabic"';
    ctx.fillText('قنوات ومجموعات التخصص', RX, 350);

    const list = col._all.slice(0, 8);
    let y = 440;
    ctx.font = '600 34px "IBM Plex Sans Arabic"';
    list.forEach(it => {
        ctx.fillStyle = '#4dd8c8';
        ctx.beginPath(); ctx.arc(RX - 8, y - 11, 7, 0, 7); ctx.fill();
        ctx.fillStyle = 'rgba(255,255,255,0.92)';
        ctx.fillText(it.name, RX - 34, y);
        y += 62;
    });
    if (col._all.length > 8) {
        ctx.fillStyle = 'rgba(255,255,255,0.6)';
        ctx.fillText('و+' + (col._all.length - 8) + ' تخصص آخر', RX - 34, y);
    }

    const link = PAGE_URL + '#' + encodeURIComponent(col._slug);
    drawQR(ctx, link, 90, H - 370, 260);

    ctx.textAlign = 'right';
    ctx.fillStyle = 'rgba(255,255,255,0.9)';
    ctx.font = '700 34px "IBM Plex Sans Arabic"';
    ctx.fillText('امسح للوصول المباشر', RX, H - 270);
    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.font = '600 26px "IBM Plex Sans Arabic"';
    ctx.fillText('لكل قنوات ' + col.name, RX, H - 225);

    ctx.fillStyle = 'rgba(255,255,255,0.08)';
    ctx.fillRect(0, H - 120, W, 120);
    ctx.textAlign = 'right';
    ctx.fillStyle = '#4dd8c8';
    ctx.font = '700 34px "IBM Plex Sans Arabic"';
    ctx.fillText('@QU_Care', RX, H - 50);
    ctx.textAlign = 'left';
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '600 26px "IBM Plex Sans Arabic"';
    ctx.fillText('دليل مجموعات التخصصات', 90, H - 50);

    return canvas;
}

function openShare(slug) {
    const col = SLUG_TO_COLLEGE[slug];
    if (!col) return;
    shareBody.innerHTML = `<div class="share-building"><i class="fas fa-spinner fa-spin"></i>جاري إنشاء الصورة...</div>`;
    openOverlay(shareOverlay);
    buildShareCanvas(col).then(canvas => {
        const dataUrl = canvas.toDataURL('image/png');
        shareBody.innerHTML = `<div class="share-preview-wrap"></div>
            <a class="share-dl" href="${dataUrl}" download="${col.name}.png"><i class="fas fa-download"></i>تنزيل الصورة</a>`;
        shareBody.querySelector('.share-preview-wrap').appendChild(canvas);
    }).catch(() => {
        shareBody.innerHTML = `<div class="share-building"><i class="fas fa-triangle-exclamation"></i>تعذّر إنشاء الصورة</div>`;
    });
}

document.getElementById('share-close').addEventListener('click', () => closeOverlay(shareOverlay));
shareOverlay.addEventListener('click', e => { if (e.target === shareOverlay) closeOverlay(shareOverlay); });

function handleClick(e) {
    const pin = e.target.closest('[data-pin]');
    if (pin) { e.preventDefault(); e.stopPropagation(); togglePin(pin.getAttribute('data-pin')); return; }
    const rep = e.target.closest('[data-report]');
    if (rep) { e.preventDefault(); e.stopPropagation(); reportLink(rep.getAttribute('data-report')); return; }
    const share = e.target.closest('[data-share]');
    if (share) { e.preventDefault(); openShare(share.getAttribute('data-share')); return; }
    const copyl = e.target.closest('[data-copylink]');
    if (copyl) {
        e.preventDefault();
        const slug = copyl.getAttribute('data-copylink');
        copyText(PAGE_URL + '#' + encodeURIComponent(slug)).then(() => toast('تم نسخ رابط الكلية'));
        return;
    }
    const head = e.target.closest('.college-head');
    if (head && resultsEl.contains(head)) {
        const card = head.parentElement;
        setCardOpen(card, !card.classList.contains('open'));
        return;
    }
    const link = e.target.closest('.item-link');
    if (link && link.dataset.url) { trackUse(link.dataset.url); setTimeout(renderPersonal, 400); }
}
document.addEventListener('click', handleClick);

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
        if (wizardOverlay.classList.contains('show')) closeOverlay(wizardOverlay);
        if (shareOverlay.classList.contains('show')) closeOverlay(shareOverlay);
        return;
    }
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const tool = e.target.closest('.item-tool');
    if (tool) { e.preventDefault(); tool.click(); return; }
    const head = e.target.closest('.college-head');
    if (head && resultsEl.contains(head)) {
        e.preventDefault();
        const card = head.parentElement;
        setCardOpen(card, !card.classList.contains('open'));
    }
});

document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
        document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
        chip.classList.add('selected');
        currentFilter = chip.dataset.filter;
        applyFilters();
    });
});

searchInput.addEventListener('input', applyFilters);
searchClear.addEventListener('click', () => { searchInput.value = ''; applyFilters(); searchInput.focus(); });

const themeToggle = document.getElementById('theme-toggle');
function setTheme(dark) {
    document.body.classList.toggle('dark', dark);
    localStorage.setItem('qu-theme', dark ? 'dark' : 'light');
}
themeToggle.addEventListener('click', () => { setTheme(!document.body.classList.contains('dark')); });
const savedTheme = localStorage.getItem('qu-theme');
const prefersDark = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)').matches : false;
if (savedTheme === 'dark' || (!savedTheme && prefersDark)) setTheme(true);

window.addEventListener('hashchange', handleHash);

render();
renderPersonal();
syncPinStates();
applyFilters();
handleHash();
</script>
</body>
</html>
